# Production settings for PythonAnywhere
SECRET_KEY=your-secure-secret-key-here-generate-a-new-one
DEBUG=False
ALLOWED_HOSTS=yourusername.pythonanywhere.com,www.yourdomain.com,yourdomain.com
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourusername.pythonanywhere.com,https://www.yourdomain.com,https://yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourusername.pythonanywhere.com,https://www.yourdomain.com,https://yourdomain.com

# Database settings (PythonAnywhere provides MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=yourusername$dbname
DB_USER=yourusername
DB_PASSWORD=your_mysql_password
DB_HOST=yourusername.mysql.pythonanywhere-services.com
DB_PORT=3306